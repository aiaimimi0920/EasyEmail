# EasyEmail minimal runtime env contract (Docker)
# Canonical runtime config lives in /etc/easy-email/config.yaml.
# Provider keys and API settings should be written in that YAML file.

EASY_EMAIL_CONFIG_PATH=/etc/easy-email/config.yaml
EASY_EMAIL_STATE_DIR=/var/lib/easy-email
EASY_EMAIL_RESET_STORE_ON_BOOT=false
